# Example only. Do not store real credentials in this repository.
#
# Preferred local setup:
# - configure AWS CLI / AWS SSO / AWS_PROFILE outside the repository
# - keep long-lived AWS access keys out of local project files when possible

# Preferred AWS auth
AWS_PROFILE=my-dev
AWS_DEFAULT_REGION=ap-southeast-2

# Optional fallback for local static credentials.
# Uncomment only if you intentionally use access keys locally.
# AWS_ACCESS_KEY_ID=replace-me
# AWS_SECRET_ACCESS_KEY=replace-me
# AWS_SESSION_TOKEN=replace-me

# Optional project settings.
# FOUNDATION_MODEL_ID is not wired into the CDK stack yet; the current stack still
# uses the constant in packages/infra-cdk/lib/bedrock-agents-stack.ts.
FOUNDATION_MODEL_ID=amazon.nova-lite-v1:0

# Optional future integration settings.
# WORK_SEARCH_ENDPOINT=https://example.internal/work-search
# RAG_BACKEND_ENDPOINT=https://example.internal/rag

# Optional Bedrock test client shortcuts.
# BEDROCK_SUPERVISOR_ALIAS_ARN=arn:aws:bedrock:ap-southeast-2:123456789012:agent-alias/AGENT_ID/ALIAS_ID
# BEDROCK_QA_ALIAS_ARN=arn:aws:bedrock:ap-southeast-2:123456789012:agent-alias/AGENT_ID/ALIAS_ID
# BEDROCK_WORK_ALIAS_ARN=arn:aws:bedrock:ap-southeast-2:123456789012:agent-alias/AGENT_ID/ALIAS_ID

# Optional RAGAS evaluator models.
# RAGAS_EVAL_LLM_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
# RAGAS_EVAL_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# Optional Python hybrid RAG service (apps/rag-service).
# Uses RAG_* first, then falls back to RDS_* where available.
# RAG_DB_HOST=your-rds-endpoint
# RAG_DB_PORT=5432
# RAG_DB_NAME=postgres
# RAG_DB_USER=postgres
# Recommended: use Secrets Manager instead of plaintext password.
# RAG_DB_PASSWORD_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-2:123456789012:secret:my-rds-secret
# RAG_DB_PASSWORD_SECRET_JSON_KEY=password
# Optional local fallback only (do not commit real values):
# RAG_DB_PASSWORD=replace-me
# RAG_DB_SSLMODE=require
# RAG_EMBED_DIM=1024
# RAG_AWS_REGION=ap-southeast-2
# RAG_ANSWER_MODEL_ID=amazon.nova-lite-v1:0
# RAG_ANSWER_MAX_TOKENS=500
# RAG_ANSWER_TEMPERATURE=0.05
# QWEN_API_KEY_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-2:123456789012:secret:qianwen_apikey
# QWEN_API_KEY_SECRET_KEY=DASHSCOPE_API_KEY
# Optional local fallback only:
# QWEN_API_KEY=replace-me
# QWEN_MODEL_ID=qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MAX_TOKENS=500
# QWEN_TEMPERATURE=0.0
# RAG_ROUTE_MIN_HITS=3
# RAG_ROUTE_TOP_SCORE_THRESHOLD=0.015
# RAG_ROUTE_COMPLEX_QUERY_TOKEN_THRESHOLD=18
# RAG_ENABLE_QUERY_REWRITE=true

# Optional extraction runtime model config.
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-plus
# RERANK_MODEL=gte-rerank
